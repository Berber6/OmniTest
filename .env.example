# =============================================================================
# OmniTest Environment Configuration
# Copy this file to .env and adjust values as needed.
# =============================================================================

# --- LLM Configuration ---
# Primary API key for LLM access (OpenAI-compatible)
LLM_API_KEY=your_api_key_here
# Alternative API key env var (checked before LLM_API_KEY)
# ISRC_API_KEY=your_api_key_here
# API base URL for all LLM models
LLM_API_BASE=https://chatbox.isrc.ac.cn/api/v1

# LiteLLM model overrides (optional - defaults shown)
# LLM_MODEL_GENERATION=openai/DeepSeek-V4-Flash
# LLM_MODEL_REASONING=openai/GLM-5.1
# LLM_MODEL_VISION=openai/Qwen3-VL-235B-A22B-Instruct

# --- Database Paths ---
# SQLite database path (maps to sqlite_path in config)
SQLITE_PATH=./data/omni_test.db
# ChromaDB persistent directory (maps to chroma_path in config)
CHROMA_PATH=./data/chroma_db

# --- Web Application Credentials (for 4gaboards demo) ---
# LOGIN_URL=https://demo.4gaboards.com/login
# LOGIN_EMAIL=your_email@example.com
# LOGIN_PASSWORD=your_password

# --- Neo4j Graph Database (optional) ---
# NEO4J_ENABLED=false
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=omnitest

# --- Execution Settings ---
# MAX_RETRY_COUNT=3

# --- CORS ---
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# --- Server ---
# HOST=0.0.0.0
# PORT=8000
